{
  "name": "portfolio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbo",
    "build": "next build",
    "optimize:images": "node scripts/optimize-images.js",
    "build:data": "node scripts/fetch-github-data.mjs",
    "prebuild": "npm run build:data",
    "build:pages": "node scripts/build-pages.js",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:unit": "vitest",
    "check:links": "node scripts/check-links.js",
    "analyze": "cross-env ANALYZE=true next build --webpack",
    "deploy:server": "node scripts/deploy-server-local.mjs",
    "deploy:server:status": "node scripts/deploy-server-status.mjs",
    "push:all": "node scripts/push-all.mjs",
    "setup:server:ci": "node scripts/setup-server-ci.mjs",
    "setup:server:https": "node scripts/setup-server-https.mjs"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "framer-motion": "^12.24.12",
    "lucide-react": "^0.562.0",
    "next": "16.1.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-ga4": "^2.1.0",
    "tailwind-merge": "^3.4.0",
    "web-vitals": "^5.1.0"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.1.1",
    "@playwright/test": "^1.57.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.3",
    "cross-env": "^7.0.3",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "fast-check": "^4.5.3",
    "jsdom": "^28.0.0",
    "next-image-export-optimizer": "^1.20.1",
    "prettier": "^3.8.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
